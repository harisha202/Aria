# === App ===
DEBUG=True
CORS_ORIGINS=http://localhost:5173

# === Database ===
# Local no-setup fallback:
DATABASE_URL=sqlite:///aria.db
# PostgreSQL production/dev option:
# DATABASE_URL=postgresql://aria_user:aria_password@localhost:5432/aria_db

# === JWT ===
SECRET_KEY=change-this-secret-in-production
JWT_SECRET=change-this-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# === Claude AI ===
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# === Gemini AI ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_DEFAULT_MODEL=claude

# === Google Cloud Voice ===
GOOGLE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CLOUD_STT_API_KEY=
GOOGLE_CLOUD_TTS_API_KEY=
GOOGLE_CLOUD_STT_LANGUAGE=en-US
GOOGLE_CLOUD_TTS_VOICE=en-US-Neural2-C

# === Email / SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
